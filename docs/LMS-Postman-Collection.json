        },
        {
          "name": "03 Login (admin) \u2b50 run first",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  if (json.user && json.user.id) {",
                  "    pm.collectionVariables.set('adminUserId', String(json.user.id));",
                  "  }",
                  "  pm.test('Login OK + tokens saved', () => {",
                  "    pm.expect(json.accessToken).to.be.a('string');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cloudnexus.com\",\n  \"password\": \"Password123!\",\n  \"rememberMe\": false\n}"
            },
